{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",      // ✅ replaces deprecated "node"
    "esModuleInterop": true,
    "declaration": true,               // ✅ removed isolatedModules (not needed)
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",                // ✅ ES2021 is safer for NestJS + CommonJS
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}